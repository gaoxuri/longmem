# ── PostgreSQL (reuse your existing PG instance) ──
PG_HOST=127.0.0.1
PG_PORT=5432
PG_NAME=longmem
PG_USER=maxkb
PG_PASSWORD=MaxKb#2026pg

# ── Embedding backend ──
# provider: openai (any OpenAI-compatible endpoint) | fallback (local, no API key)
EMBED_PROVIDER=fallback
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small
# Must match the real embedding dimension: 384 (fallback) | 1536 (text-embedding-3-small)
EMBED_DIM=384

# ── Optional LLM summarization ──
# Set SUMMARY_ENABLED=true and fill LLM_* to auto-summarize long memories
SUMMARY_ENABLED=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Defaults ──
DEFAULT_TOP_K=5
DEFAULT_THRESHOLD=0.0

# ── Service ──
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8123
